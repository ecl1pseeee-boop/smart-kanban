{
  "name": "smart-kanban",
  "version": "0.1.0",
  "private": true,
  "description": "Smart Kanban — real-time Jira/Trello-like with AI automation and Telegram bot (ЮНИТХАК)",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter @smart-kanban/api run db:migrate",
    "db:seed": "pnpm --filter @smart-kanban/api run db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "prettier": "^3.3.3",
    "eslint": "^9.15.0",
    "@types/node": "^20.17.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma"
    ]
  }
}
