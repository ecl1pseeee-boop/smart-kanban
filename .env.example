# ── Database ──────────────────────────────────────────
POSTGRES_USER=kanban_user
POSTGRES_PASSWORD=kanban_dev_password
POSTGRES_DB=smart_kanban
DATABASE_URL=postgresql://kanban_user:kanban_dev_password@localhost:5432/smart_kanban

# ── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=redis_dev_password
REDIS_URL=redis://:redis_dev_password@localhost:6379

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=minimum_32_chars_random_string_here_replace_me
JWT_REFRESH_SECRET=another_32_chars_random_string_here_replace
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── API ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# ── AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI ключ нужен только для /api/ai/process-voice (Whisper STT).
# Без него эндпоинт вернёт 503.
OPENAI_API_KEY=sk-...
WHISPER_MODEL=whisper-1

# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
BOT_SECRET=internal_secret_for_bot_to_api_calls
WEBHOOK_URL=https://yourdomain.com/api/telegram-webhook

# ── Frontend (Vite) ───────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001

# ── URLs (для docker-compose) ─────────────────────────
API_URL=http://localhost:3001
WS_URL=http://localhost:3001
